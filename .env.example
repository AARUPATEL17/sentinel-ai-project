# SENTINEL v3.0 — Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+91XXXXXXXXXX

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
ALERT_EMAIL_TO=commander@sentinel.gov

# ── AI Chatbot ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Flask API ─────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_SECRET=change-this-secret-key-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no config needed)
DB_PATH=database/sentinel.db

# MySQL (optional alternative)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=sentinel_user
# MYSQL_PASS=yourpassword
# MYSQL_DB=sentinel_db

# Firebase (optional alternative)
# FIREBASE_CREDENTIALS=path/to/serviceAccountKey.json
# FIREBASE_PROJECT_ID=your-project-id
